    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from tensorflow.keras.models import load_model\n",
    "\n",
    "# Load dataset\n",
    "data = np.load(\"ml_training_data/training_data.npz\")\n",
    "X = data[\"waveforms\"]\n",
    "y_true = data[\"labels\"]  # shape: (n_samples, max_signals, 3)\n",
    "counts_true = data[\"counts\"]\n",
    "time = data[\"time\"]\n",
    "\n",
    "# Load model and normalize input\n",
    "model = load_model(\"ml_training_data/signal_extraction_model.keras\")\n",
    "X_mean = X.mean(axis=1, keepdims=True)\n",
    "X_std = X.std(axis=1, keepdims=True)\n",
    "X_norm = (X - X_mean) / (X_std + 1e-8)\n",
    "\n",
    "# Predict\n",
    "pred_signal, pred_count = model.predict(X_norm)\n",
    "max_signals = y_true.shape[1]\n",
    "pred_signal = pred_signal.reshape((-1, max_signals, 3))\n",
    "pred_count_labels = np.argmax(pred_count, axis=1)\n",
    "\n",
    "# Extract true values\n",
    "true_t0s = y_true[:, :, 0]\n",
    "true_amps = y_true[:, :, 1]\n",
    "true_presence = y_true[:, :, 2]\n",
    "\n",
    "# Extract predicted values\n",
    "pred_t0s = pred_signal[:, :, 0]\n",
    "pred_amps = pred_signal[:, :, 1]\n",
    "pred_presence = pred_signal[:, :, 2]\n",
    "\n",
    "# Plotting\n",
    "fig, axes = plt.subplots(3, 1, figsize=(12, 15))\n",
    "\n",
    "# Plot 1: t0s\n",
    "for i in range(max_signals):\n",
    "    axes[0].scatter(true_t0s[:, i], pred_t0s[:, i], label=f'Signal {i+1}', alpha=0.6)\n",
    "axes[0].plot([true_t0s.min(), true_t0s.max()], [true_t0s.min(), true_t0s.max()], 'k--')\n",
    "axes[0].set_title(\"Predicted vs True t₀\")\n",
    "axes[0].set_xlabel(\"True t₀ (ns)\")\n",
    "axes[0].set_ylabel(\"Predicted t₀ (ns)\")\n",
    "axes[0].grid(True)\n",
    "axes[0].legend()\n",
    "\n",
    "# Plot 2: Amplitudes\n",
    "for i in range(max_signals):\n",
    "    axes[1].scatter(true_amps[:, i], pred_amps[:, i], label=f'Signal {i+1}', alpha=0.6)\n",
    "axes[1].plot([true_amps.min(), true_amps.max()], [true_amps.min(), true_amps.max()], 'k--')\n",
    "axes[1].set_title(\"Predicted vs True Amplitudes\")\n",
    "axes[1].set_xlabel(\"True Amplitude\")\n",
    "axes[1].set_ylabel(\"Predicted Amplitude\")\n",
    "axes[1].grid(True)\n",
    "axes[1].legend()\n",
    "\n",
    "# Plot 3: Number of Signals\n",
    "unique_counts = np.unique(counts_true)\n",
    "hist_bins = np.arange(unique_counts.min(), unique_counts.max() + 2) - 0.5\n",
    "axes[2].hist(counts_true, bins=hist_bins, alpha=0.6, label=\"True Count\")\n",
    "axes[2].hist(pred_count_labels, bins=hist_bins, alpha=0.6, label=\"Predicted Count\")\n",
    "axes[2].set_xticks(unique_counts)\n",
    "axes[2].set_title(\"Signal Count Distribution\")\n",
    "axes[2].set_xlabel(\"Signal Count\")\n",
    "axes[2].set_ylabel(\"Frequency\")\n",
    "axes[2].grid(True)\n",
    "axes[2].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"ml_training_data/predicted_vs_truth_plots.png\")\n",
    "plt.show()\n"
